  "help": {
    "title": "ಸಹಾಯ ಮತ್ತು ಸಹಾಯತೆ",
    "faq": "ಆಗಾಗ ಕೇಳಲಾಗುವ ಪ್ರಶ್ನೆಗಳು",
    "faqs": {
      "q1": "ನಾನು ದೂರು ದಾಖಲಿಸುವುದು ಹೇಗೆ?",
      "a1": "'SOS' ಬಟನ್ ಅನ್ನು ಕ್ಲಿಕ್ ಮಾಡಿ ಅಥವಾ ಹೊಸ ದೂರು ದಾಖಲಿಸಲು 'ದೂರುಗಳು' ವಿಭಾಗಕ್ಕೆ ಹೋಗಿ.",
      "q2": "ನಿರೀಕ್ಷಿತ ಪ್ರತಿಕ್ರಿಯೆ ಸಮಯ ಏನು?",
      "a2": "ದೂರುಗಳು 24-48 ಗಂಟೆಗಳಲ್ಲಿ ಪರಿಶೀಲಿಸಲಾಗುತ್ತದೆ ಮತ್ತು ನೀವು ಸ್ಥಿತಿ ನವೀಕರಣ ಪಡೆಯುವಿರಿ.",
      "q3": "ನಾನು ಎಂದೆ ಸುರಕ್ಷೆಯನ್ನು ಹೇಗೆ ಟ್ರ್ಯಾಕ್ ಮಾಡುವುದು?",
      "a3": "ಎಲ್ಲಾ ಸುರಕ್ಷೆಗಳ ಪ್ರವರ್ತಮಾನ ಸ್ಥಿತಿ ಮತ್ತು ಇತಿಹಾಸವನ್ನು ನೋಡಲು 'ನನ್ನ ದೂರುಗಳು' ವಿಭಾಗವನ್ನು ಬಳಸಿ.",
      "q4": "ನೀವು ಪ್ರತಿಕ್ರಿಯೆ ಪಡೆದಿಲ್ಲ ಎಂದರೆ?",
      "a4": "48 ಗಂಟೆಗಳಲ್ಲಿ ಪ್ರತಿಕ್ರಿಯೆ ಇಲ್ಲ ಎಂದರೆ, ದೂರು ಸ್ವಯಂಚಾಲಿತವಾಗಿ ಉಚ್ಚ ಸ್ತರದ ಪರಿಶೀಲನೆಯನ್ನು ಹೆಚ್ಚಿಸಲಾಗುತ್ತದೆ.",
      "q5": "ನಾನು ಬಿದ್ಯಮಾನ ದೂರುವನ್ನು ಹೇಗೆ ಸಂಪಾದಿಸುವುದು?",
      "a5": "ನೀವು ಪ್ರಗತಿ ಅಥವಾ ಪರಿಶೀಲನೆಯಲ್ಲಿರುವ ದೂರುಗಳನ್ನು ಸಂಪಾದಿಸಬಹುದು. ದೂರು ತೆರೆಯಿರಿ ಮತ್ತು 'ಸಂಪಾದಿಸು' ಎಂಬುದನ್ನು ಕ್ಲಿಕ್ ಮಾಡಿ.",
      "q6": "ದೂರು ದಾಖಲಿಸಲು ಯಾವುದೋ ಶುಲ್ಕ ಇದೆಯೇ?",
      "a6": "ಇಲ್ಲ, ಎಲ್ಲಾ ಸೇವೆಗಳು ಸಂಪೂರ್ಣ ಉಚಿತ. ಎಂದೇ ನೋಂದಣಿ ಅಥವಾ ಪ್ರಕ್ರಿಯಾಕರಣ ಶುಲ್ಕ ಇಲ್ಲ.",
      "q7": "ನಾನು ಹೇಗೆ ಮಾಹಿತಿ ಒದಗಿಸುವುದು?",
