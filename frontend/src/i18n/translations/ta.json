  "help": {
    "title": "உதவி மற்றும் ஆதரவு",
    "faq": "அடிக்கடி கேட்கப்பட்ட கேள்விகள்",
    "faqs": {
      "q1": "நான் ஒரு புகாரை எப்படி பதிவு செய்வேன்?",
      "a1": "'SOS' பொத்தானைக் கிளிக் செய்யவும் அல்லது புதிய புகாரைப் பதிவு செய்ய 'புகார்' பிரிவுக்குச் செல்லவும்.",
      "q2": "எதிர்பார்க்கப்பட்ட பதিலளிப்பு நேரம் என்ன?",
      "a2": "புகார்கள் 24-48 மணிநேரத்திற்குள் மதிப்பாய்வு செய்யப்படுகிறது மற்றும் நீங்கள் ஒரு நிலை புதுப்பির்ப்பைப் பெறுவீர்கள்.",
      "q3": "என் புகாரை நான் எவ்வாறு பின்தொடர்ந்து செல்லலாம்?",
      "a3": "உங்கள் அனைத்துப் புகார்களின் தற்போதைய நிலை மற்றும் வரலாற்றைக் காண 'எனது புகார்கள்' பிரிவைப் பயன்படுத்தவும்.",
      "q4": "நான் பதிலளிப்பு இல்லை என்றால் என்ன செய்வது?",
      "a4": "48 மணிநேரத்திற்குள் பதிலளிப்பு இல்லை என்றால், புகாரைத் தானாக உচ்চতর স்তரের மதிப்பாய்வுக்கு மாற்றி விடப்படும்.",
      "q5": "நான் ஒரு বিদ்যமান புகாரை எவ்வாறு திருத்தி சொல்லலாம்?",
      "a5": "நீங்கள் உடன்பட்ட அல்லது நிலுவையில் உள்ள புகார்களைத் திருத்தலாம். புகாரைத் திறந்து 'திருத்து' என்பதைக் கிளிக் செய்யவும்.",
      "q6": "ஒரு புகாரைப் பதிவு செய்ய ஏதேனும் கட்டணம் உள்ளதா?",
      "a6": "இல்லை, அனைத்துப் பணிகளும் முற்றிலும் இலவசம். பதிவுசெய்தல் அல்லது செயலாக்குதல் கட்டணம் இல்லை.",
      "q7": "நான் எவ்வாறு கருத்து அளிக்கலாம்?",
      "a7": "உதவி பிரிவில் கருத்து படிவத்தைப் பயன்படுத்தவும் அல்லது support@vyavastha.gov.in க்கு ஈமெயல் அனுப்பவும்.",
      "q8": "நான் என் கடவுச்சொல்லை எப்படி மீட்டமைப்பு செய்வேன்?",
