  "help": {
    "title": "मदत आणि समर्थन",
    "faq": "वारंवार विचारले जाणारे प्रश्न",
    "faqs": {
      "q1": "मी तक्रार कसे दाखल करतो?",
      "a1": "'SOS' बटण दाबा किंवा नवीन तक्रार दाखल करण्यासाठी 'तक्रार' विभागात जा.",
      "q2": "अपेक्षित प्रतिक्रिया वेळ काय आहे?",
      "a2": "तक्रारी 24-48 तासांत पुनरावलोकन केल्या जातात आणि आपल्याला स्थिती अपडेट मिळेल.",
      "q3": "मी माझी तक्रार कसे ट्रॅक करू शकतो?",
      "a3": "आपल्या सर्व तक्रारीची वर्तमान स्थिती आणि इतिहास पाहण्यासाठी 'माझ्या तक्रारी' विभाग वापरा.",
      "q4": "जर मुझे प्रतिक्रिया न मिळाल्यास?",
      "a4": "जर 48 तासांत कोणीही प्रतिक्रिया न दिल्यास, तक्रार स्वयंचलितपणे उच्च स्तरीय पुनरावलोकनासाठी वर्धित केली जाईल.",
      "q5": "मी विद्यमान तक्रार कसे संपादित करू शकतो?",
      "a5": "आप चालू असलेल्या किंवा प्रलंबित तक्रारी संपादित करू शकता. तक्रार उघडा आणि 'संपादित करा' दाबा.",
      "q6": "तक्रार दाखल करण्यासाठी काही शुल्क आहे का?",
      "a6": "नाही, सर्व सेवा पूर्णपणे विनामूल्य आहेत. कोणत्याही नोंदणी किंवा प्रक्रिया शुल्क नाही.",
      "q7": "मी प्रतिक्रिया कसे दिऊ शकतो?",
      "a7": "मदत विभागात प्रतिक्रिया फॉर्म वापरा किंवा support@vyavastha.gov.in ला ईमेल पाठवा.",
      "q8": "मी माझा पासवर्ड कसे रीसेट करू शकतो?",
      "a8": "लॉगिन स्क्रीनवर 'पासवर्ड विसरले' दाबा आणि आपल्या नोंदणीकृत ईमेल पत्त्यावर पाठवलेल्या सूचनांचे अनुसरण करा."
    },
