  "help": {
    "title": "Pomoc i Wsparcie",
    "faq": "Często Zadawane Pytania",
    "faqs": {
      "q1": "Jak zgłosić skargę?",
      "a1": "Kliknij przycisk 'SOS' lub przejdź do sekcji 'Skargi', aby zgłosić nową skargę.",
      "q2": "Jaki jest oczekiwany czas odpowiedzi?",
      "a2": "Skargi są przeglądane w ciągu 24-48 godzin i otrzymasz aktualizację statusu.",
      "q3": "Jak mogę śledzić moją skargę?",
      "a3": "Użyj sekcji 'Moje Skargi', aby wyświetlić bieżący status i historię wszystkich Twoich skarg.",
      "q4": "Co zrobić, jeśli nie otrzymam odpowiedzi?",
      "a4": "Jeśli w ciągu 48 godzin nie będzie odpowiedzi, skarga zostanie automatycznie eskalowana do przeglądu wyższego poziomu.",
      "q5": "Jak mogę edytować istniejącą skargę?",
      "a5": "Możesz edytować skargi w toku lub oczekujące. Otwórz skargę i kliknij 'Edytuj'.",
      "q6": "Czy jest opłata za zgłoszenie skargi?",
      "a6": "Nie, wszystkie usługi są całkowicie bezpłatne. Brak opłat rejestracyjnych lub przetwarzania.",
      "q7": "Jak mogę wyrazić opinię?",
      "a7": "Użyj formularza opinii w sekcji Pomoc lub wyślij e-mail na support@vyavastha.gov.in",
      "q8": "Jak zresetować hasło?",
      "a8": "Kliknij 'Zapomniałem hasła' na ekranie logowania i postępuj zgodnie z instrukcjami wysłanymi na Twój zarejestrowany adres e-mail."
    },
