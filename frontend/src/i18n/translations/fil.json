  "help": {
    "title": "Tulong at Suporta",
    "faq": "Mga Madalas na Tanong",
    "faqs": {
      "q1": "Paano ako magsumite ng reklamo?",
      "a1": "I-click ang buton na 'SOS' o mag-navigate sa seksyon ng 'Mga Reklamo' upang magsumite ng bagong reklamo.",
      "q2": "Ano ang inaasahang oras ng tugon?",
      "a2": "Ang mga reklamo ay sinusuri sa loob ng 24-48 oras at makakatanggap ka ng update ng status.",
      "q3": "Paano ko ma-track ang aking reklamo?",
      "a3": "Gamitin ang seksyon na 'Ang Aking Mga Reklamo' upang makita ang kasalukuyang status at kasaysayan ng lahat ng iyong mga reklamo.",
      "q4": "Ano ang dapat gawin kung hindi ako makakatanggap ng tugon?",
      "a4": "Kung walang tugon sa loob ng 48 oras, ang reklamo ay awtomatikong ama-escalate para sa review sa mas mataas na antas.",
      "q5": "Paano ako maaaring mag-edit ng umiiral nang reklamo?",
      "a5": "Maaari mong baguhin ang mga reklamo na nagsisimula o naghihintay. Buksan ang reklamo at i-click ang 'I-edit'.",
      "q6": "May bayad ba para magsumite ng reklamo?",
      "a6": "Hindi, lahat ng serbisyo ay lubhang libre. Walang bayad sa pagpaparehistro o pagpoproseso.",
      "q7": "Paano ako maaaring magbigay ng feedback?",
      "a7": "Gamitin ang feedback form sa seksyon na Tulong o magpadala ng email sa support@vyavastha.gov.in",
      "q8": "Paano ako makakabalik sa aking password?",
      "a8": "I-click ang 'Nakalimutan ang password' sa login screen at sundin ang mga tagubilin na ipinapadala sa iyong naka-register na email address."
    },
