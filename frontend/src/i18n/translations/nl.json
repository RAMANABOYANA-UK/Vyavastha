  "help": {
    "title": "Hulp en Ondersteuning",
    "faq": "Veelgestelde Vragen",
    "faqs": {
      "q1": "Hoe registreer ik een klacht?",
      "a1": "Klik op de knop 'SOS' of ga naar het onderdeel 'Klachten' om een nieuwe klacht in te dienen.",
      "q2": "Wat is de verwachte responstijd?",
      "a2": "Klachten worden binnen 24-48 uur beoordeeld en u ontvangt een statusupdate.",
      "q3": "Hoe kan ik mijn klacht volgen?",
      "a3": "Gebruik het onderdeel 'Mijn Klachten' om de huidge status en geschiedenis van al uw klachten te zien.",
      "q4": "Wat moet ik doen als ik geen antwoord krijg?",
      "a4": "Als er binnen 48 uur geen antwoord is, wordt de klacht automatisch geëscaleerd voor hoger niveau review.",
      "q5": "Hoe kan ik een bestaande klacht bewerken?",
      "a5": "U kunt ausstekende klachten in afwachting bewerken. Open de klacht en klik op 'Bewerken'.",
      "q6": "Is er een vergoeding voor het indienen van een klacht?",
      "a6": "Nee, alle services zijn volledig gratis. Geen registratie- of verwerkingskosten.",
      "q7": "Hoe kan ik feedback geven?",
      "a7": "Gebruik het feedbackformulier in het onderdeel Hulp of stuur een e-mail naar support@vyavastha.gov.in",
      "q8": "Hoe stel ik mijn wachtwoord opnieuw in?",
      "a8": "Klik op 'Wachtwoord vergeten' op het aanmeldingsscherm en volg de instructies in uw geregistreerde e-mail."
    },
